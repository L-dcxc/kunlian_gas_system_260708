# Python cache and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Runtime data generated by local development runs. Keep data/*/.gitkeep files.
data/config/*
data/db/*
data/maps/*
data/backups/*
data/logs/*
!data/maps/.gitkeep
!data/backups/.gitkeep
!data/logs/.gitkeep

# Build artifacts
build/
dist/
*.spec
!packaging/app.spec
